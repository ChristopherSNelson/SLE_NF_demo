/*
 * SLE Methylation Pipeline - Nextflow Config
 */

manifest {
    name            = 'SLE-methylation-pipeline'
    author          = 'SLE Pipeline Team'
    description     = 'BWA-meth + ComBat-meth DSL2 pipeline for SLE methylation analysis'
    version         = '0.1.0'
    nextflowVersion = '>=22.10.0'
    defaultBranch   = 'main'
}

params {
    // Input
    sample_sheet = null
    genome       = null
    ref_panel    = "${projectDir}/assets/salas_2018_cpgs.csv"
    genome_fai       = null   // auto-derived from genome if null
    genome_index_dir = null   // storeDir for bwameth index; null = local genome_index/

    // Output
    outdir       = './results'

    // MethylDackel
    min_depth    = 5

    // NMF
    nmf_kmin     = 2
    nmf_kmax     = 8
    nmf_nruns    = 30

    // Region detection
    window_size  = 1000
    step_size    = 500
    min_cpgs     = 3

    // Skip alignment (use pre-made bedGraphs for testing downstream steps)
    skip_alignment = false
    bedgraph_dir   = null

    // Stop after methylation extraction (skip cohort-level steps)
    alignment_only = false

    // Optional clinical metadata TSV for NMF correlation analysis
    clinical_metadata = null

    // General
    help         = false
}

// ---- Resume by default ----
// Skips completed tasks on re-run. Override with -resume false.
resume = true

// ---- Error handling & crash recovery ----
process {
    // Retry transient failures (cloud preemption, OOM) up to 3 times
    errorStrategy = { task.exitStatus in [137, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 3

    // Resource labels with dynamic scaling on retry, capped to machine limits (8 CPU, 16 GB)
    withLabel: 'process_low' {
        cpus   = { Math.min(1 * task.attempt, 4) }
        memory = { [2.GB * task.attempt, 8.GB].min() }
        time   = { 1.h * task.attempt }
    }
    withLabel: 'process_medium' {
        cpus   = { Math.min(2 * task.attempt, 6) }
        memory = { [4.GB * task.attempt, 12.GB].min() }
        time   = { 4.h * task.attempt }
    }
    withLabel: 'process_high' {
        cpus   = { [4 * task.attempt, 6].min() }
        memory = { [12.GB * task.attempt, 12.GB].min() }
        time   = { 48.h * task.attempt }
    }
}

// ---- Profiles ----
profiles {

    // -- Environment profiles --
    conda {
        conda.enabled       = true
        conda.useMicromamba  = false
    }

    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }

    // -- Executor profiles --
    local {
        executor.name   = 'local'
        executor.cpus   = 6        // M1 Pro 16GB Safeguard: Reserve 2 cores for OS
        executor.memory = '12.GB'  // Reserve 4GB for OS/Background to prevent thrashing
    }

    slurm {
        executor.name       = 'slurm'
        executor.queueSize  = 50
        executor.submitRateLimit = '10/1min'
        queue = 'normal'
    }

    aws {
        executor.name = 'awsbatch'
        process.queue = 'sle-pipeline-queue'
        aws.region    = 'us-east-2'

        // S3 work dir required for AWS Batch
        workDir = 's3://sle-methylation-pipeline/work'

        // Genome index storeDir on S3 (so BWAMETH_INDEX runs on AWS, not skipped from local cache)
        params.genome_index_dir = 's3://sle-methylation-pipeline/genome_index'

        // Wave auto-builds containers from conda YAMLs (no ECR needed)
        wave.enabled   = true
        wave.strategy  = ['conda']
        fusion.enabled = true
        docker.enabled = true
        tower.accessToken = System.getenv('TOWER_ACCESS_TOKEN')

        // Raise resource caps for cloud instances
        process {
            withLabel: 'process_low' {
                cpus   = { [2 * task.attempt, 4].min() }
                memory = { [4.GB * task.attempt, 16.GB].min() }
            }
            withLabel: 'process_medium' {
                cpus   = { [4 * task.attempt, 8].min() }
                memory = { [8.GB * task.attempt, 32.GB].min() }
            }
            withLabel: 'process_high' {
                cpus   = { [4 * task.attempt, 8].min() }
                memory = { [24.GB * task.attempt, 48.GB].min() }
            }
        }
    }

    gcloud {
        executor.name = 'google-lifesciences'
        google.project = 'YOUR-PROJECT'
        google.region  = 'us-central1'

        // GCS work dir required
        workDir = 'gs://YOUR-BUCKET/work'

        // Preemptible VMs for cost savings
        google.lifeSciences.preemptible = true
    }

    // -- Test profile --
    test {
        includeConfig 'conf/test.config'
    }
}

// ---- Capture pipeline info ----
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
}
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/report.html"
}
trace {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    fields    = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_info/dag.svg"
}
