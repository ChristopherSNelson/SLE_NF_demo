/*
 * Test profile configuration
 * Generates simulated chr22 bisulfite sequencing data for 4 samples.
 * Target runtime: ~5 minutes with conda environments cached.
 */

params {
    // Test sample sheet (generated by bin/generate_test_data.py)
    sample_sheet   = "${projectDir}/test_data/samples.csv"
    genome         = "${projectDir}/test_data/chr22.fa"
    genome_fai     = "${projectDir}/test_data/chr22.fa.fai"
    outdir         = "${projectDir}/results_test"

    // Skip alignment — use pre-made bedGraphs to test downstream steps
    skip_alignment = true
    bedgraph_dir   = "${projectDir}/test_data/bedgraphs"

    // Reduced params for speed
    min_depth    = 1
    nmf_kmin     = 2
    nmf_kmax     = 3
    nmf_nruns    = 5
    window_size  = 5000
    step_size    = 2500
    min_cpgs     = 2
}

// Reduced resources for local/CI testing
process {
    withLabel: 'process_low' {
        cpus   = 1
        memory = '2.GB'
        time   = '30.m'
    }
    withLabel: 'process_medium' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
    withLabel: 'process_high' {
        cpus   = 2
        memory = '4.GB'
        time   = '2.h'
    }
}
